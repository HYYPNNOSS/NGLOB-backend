// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum Role {
  CUSTOMER
  DRIVER
  MANAGER
  ADMIN
}

enum DriverStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentStatus {
  NOT_PROVIDED
  UPLOADED
  APPROVED
  REJECTED
}

enum ManagerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingType {
  FULL_HOUSE
  FEW_ITEMS
}

enum HomeSize {
  STUDIO
  ONE
  TWO
  THREE
  FOUR_PLUS
}

enum ExtrasType {
  MATERIALS_ONLY
  FULL_PACKING
}

enum BookingStatus {
  PENDING
  CONFIRMED
  SCHEDULED
  LOADED
  IN_TRANSIT
  UNLOADING
  DELIVERED
  UNREACHABLE
  CANCELLED
}

enum TimeSlot {
  SLOT_08_12
  SLOT_10_14
  SLOT_12_16
  SLOT_14_18
  SLOT_16_20
  EXACT
}

enum PackingMaterialType {
  MEDIUM_BOX
  LARGE_BOX
  BUBBLE_WRAP
  PAPER_ROLL
  TAPE
}

enum StorageStatus {
  ACTIVE
  CANCELLED
}

enum DeliveryStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  DEBT
  TRANSFER
}

enum ItemCategory {
  FURNITURE
  APPLIANCES
  BOXES
  DECOR_OTHER
}

// ─── Models ──────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String?
  name        String
  phone       String?
  role        Role     @default(CUSTOMER)
  provider    String?  @default("local") // "local", "google", "apple", "facebook"
  providerId   String?
  walletBalance Float   @default(0)
  outstandingDebt Float  @default(0)
  referralCode String?  @unique
  referredById String?
  referredBy   User?    @relation("Referrals", fields: [referredById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings           Booking[]           @relation("CustomerBookings")
  driver             Driver?
  storages           Storage[]
  refreshTokens      RefreshToken[]
  bonusHistory       BonusHistory[]
  managerApplication ManagerApplication?
  referredUsers      User[]              @relation("Referrals")

  notifications Notification[]
  draftQuotes   DraftQuote[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique @db.VarChar(512)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Driver {
  id                 String       @id @default(cuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentLat         Float?
  currentLng         Float?
  locationUpdatedAt  DateTime?
  isOnline           Boolean      @default(false)
  status             DriverStatus @default(PENDING)
  licensingAuthority String? // e.g. "London", "Birmingham"
  hasVan             Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  bookings     Booking[]
  crewBookings BookingCrew[]
  documents    DriverDocument[]
  availability DriverAvailability[]

  @@map("drivers")
}

model DriverAvailability {
  id        String   @id @default(cuid())
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0=Sun, 1=Mon, … 6=Sat
  startTime String // "08:00"
  endTime   String // "18:00"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([driverId, dayOfWeek])
  @@map("driver_availability")
}

model DriverDocument {
  id         String         @id @default(cuid())
  driverId   String
  driver     Driver         @relation(fields: [driverId], references: [id], onDelete: Cascade)
  docType    String // e.g. "dvla_driving_license", "mot_test_certificate"
  label      String // Human-readable label
  fileName   String? // Original uploaded file name
  fileUrl    String? // Path or URL to the stored file
  status     DocumentStatus @default(NOT_PROVIDED)
  reviewNote String?        @db.Text // Manager's note on rejection
  uploadedAt DateTime?
  reviewedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([driverId, docType])
  @@map("driver_documents")
}

model Booking {
  id         String  @id @default(cuid())
  bookingRef String  @unique // e.g. REM2409
  userId     String
  user       User    @relation("CustomerBookings", fields: [userId], references: [id])
  driverId   String?
  driver     Driver? @relation(fields: [driverId], references: [id])
  crew       BookingCrew[]

  type   BookingType
  status BookingStatus @default(PENDING)

  pickupAddress      String
  destinationAddress String
  pickupDate         DateTime
  pickupTimeSlot     TimeSlot
  estimatedDuration  Int // minutes

  homeSize       HomeSize?
  moversCount    Int        @default(2)
  extras         ExtrasType @default(MATERIALS_ONLY)
  withStorage    Boolean    @default(false)
  notesForDriver String?

  // Pricing breakdown (stored at booking time)
  loadingTimeMins      Int
  travelTimeMins       Int
  baseCost             Float
  additionalMoverCost  Float @default(0)
  fuelCost             Float
  fullPackingCost      Float @default(0)
  packingMaterialsCost Float @default(0)
  totalPrice           Float

  // Deposit support
  depositAmount   Float?
  depositPaidAt   DateTime?
  remainingAmount Float?
  remainingDueAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items            BookingItem[]
  packingMaterials PackingMaterial[]
  payments         Payment[]
  storage          Storage?
  promoCodeId      String?
  promoCode        PromoCode?        @relation(fields: [promoCodeId], references: [id])
  discountAmount   Float?            @default(0)

  exactPickupTime String?
  exactTimeFee    Float?  @default(0)

  city String? // city extracted from pickupAddress for manager filtering

  loadProofPhoto String? @db.Text // Cloudinary URL of loaded truck photo
  extraItemPhoto String? @db.Text // Cloudinary URL of extra items photo
  extraItemPrice Float?           // Price for extra items
  extraItemPaymentMethod PaymentMethod?

  extraTimeHours   Float?   // How many extra hours the job took
  extraTimeCost    Float?   // Calculated cost of extra time
  extraTimePayment PaymentMethod?

  auditLogs AuditLog[]

  @@map("bookings")
}

model BookingItem {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  name         String
  category     ItemCategory
  catalogItemId String?
  catalogItem  CatalogItem? @relation(fields: [catalogItemId], references: [id])
  widthCm      Float
  heightCm     Float
  depthCm      Float
  volumeM3     Float
  weightKg     Float?
  quantity     Int          @default(1)
  pricePerUnit Float

  room         String?
  isOversized  Boolean      @default(false)
  flagReason   String?      @db.Text // Set by system or manager
  driverFlagged Boolean     @default(false)
  driverFlagNote String?    @db.Text // Set by driver in the app
  customerApproved Boolean  @default(true)
  addedByDriver Boolean     @default(false)
  photoUrl     String?      @db.Text

  @@map("booking_items")
}

model BookingCrew {
  id        String @id @default(cuid())
  bookingId String
  driverId  String

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([bookingId, driverId])
  @@map("booking_crew")
}

model PackingMaterial {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type         PackingMaterialType
  quantity     Int
  pricePerUnit Float

  @@map("packing_materials")
}

model Storage {
  id         String   @id @default(cuid())
  storageRef String   @unique // e.g. STR679011
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  bookingId  String?  @unique
  booking    Booking? @relation(fields: [bookingId], references: [id])

  status          StorageStatus @default(ACTIVE)
  weeklyPrice     Float
  autoRenew       Boolean       @default(true)
  deliveryAddress String
  paymentMethodId String? // Stripe payment method ID

  startDate   DateTime  @default(now())
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items      StorageItem[]
  deliveries StorageDelivery[]
  payments   Payment[]

  volumeM3       Float     @default(4.5)
  returnAddress  String?
  returnDate     DateTime?
  returnTimeSlot TimeSlot?

  @@map("storages")
}

model StorageItem {
  id        String  @id @default(cuid())
  storageId String
  storage   Storage @relation(fields: [storageId], references: [id], onDelete: Cascade)

  name         String
  widthCm      Float?
  heightCm     Float?
  depthCm      Float?
  pricePerWeek Float
  addedAt      DateTime @default(now())
  
  deliveries   StorageDeliveryItem[]

  @@map("storage_items")
}

model StorageDelivery {
  id        String  @id @default(cuid())
  storageId String
  storage   Storage @relation(fields: [storageId], references: [id])

  status           DeliveryStatus @default(SCHEDULED)
  deliveryAddress  String
  deliveryDate     DateTime
  deliveryTimeSlot TimeSlot
  cost             Float          @default(0) // 0 = free first delivery

  scheduledAt DateTime  @default(now())
  completedAt DateTime?

  payments Payment[]
  items    StorageDeliveryItem[]

  @@map("storage_deliveries")
}

model StorageDeliveryItem {
  id                String          @id @default(cuid())
  storageDeliveryId String
  storageDelivery   StorageDelivery @relation(fields: [storageDeliveryId], references: [id], onDelete: Cascade)
  storageItemId     String
  storageItem       StorageItem     @relation(fields: [storageItemId], references: [id], onDelete: Cascade)

  @@unique([storageDeliveryId, storageItemId])
  @@map("storage_delivery_items")
}

model Payment {
  id                    String        @id @default(cuid())
  stripePaymentIntentId String        @unique
  amount                Float
  currency              String        @default("gbp")
  status                PaymentStatus @default(PENDING)

  bookingId         String?
  booking           Booking?         @relation(fields: [bookingId], references: [id])
  storageId         String?
  storage           Storage?         @relation(fields: [storageId], references: [id])
  storageDeliveryId String?
  storageDelivery   StorageDelivery? @relation(fields: [storageDeliveryId], references: [id])

  isDeposit Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model BonusHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float    @default(0) // positive = earned, negative = spent
  action    String   // description
  createdAt DateTime @default(now())

  @@map("bonus_history")
}

// Catalog (seeded, not user-created)
model CatalogItem {
  id        String       @id @default(cuid())
  name      String
  category  ItemCategory
  widthCm   Float
  heightCm  Float
  depthCm   Float
  volumeM3  Float
  basePrice Float // £ per item for removal

  bookingItems BookingItem[]

  @@map("catalog_items")
}

enum PromoCodeType {
  PERCENT
  FIXED
}

model PromoCode {
  id        String        @id @default(cuid())
  code      String        @unique
  type      PromoCodeType
  value     Float // 20 = 20% or £20 fixed
  maxUses   Int?
  usedCount Int           @default(0)
  expiresAt DateTime?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())

  uses     PromoCodeUse[]
  bookings Booking[]

  @@map("promo_codes")
}

model PromoCodeUse {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  userId      String?
  bookingId   String?
  usedAt      DateTime  @default(now())

  @@map("promo_code_uses")
}

// ─── Manager Applications ────────────────────────────────────

model ManagerApplication {
  id         String        @id @default(cuid())
  userId     String        @unique
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience String?       @db.Text // brief work experience
  phone      String?
  status     ManagerStatus @default(PENDING)
  adminNotes String?       @db.Text
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("manager_applications")
}

// ─── Phase 1: New Models ────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actorId   String   // The user ID who made the change
  action    String   // Description of change, e.g., "ITEM_ADDED", "PRICE_UPDATED"
  before    String?  @db.LongText // JSON representation of previous state
  after     String?  @db.LongText // JSON representation of new state
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

enum NotificationType {
  ITEM_ADDED
  APPROVAL_REQUIRED
  DELAY_ALERT
  STATUS_CHANGE
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  metadata  String?          @db.LongText // Optional JSON payload (e.g. bookingId)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model DraftQuote {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stateData   String   @db.LongText // Full JSON representation of the booking form
  totalPrice  Float?   // Estimated total if available
  pickup      String?
  destination String?
  expiresAt   DateTime // Quotes usually expire after some time
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
  @@map("draft_quotes")
}
